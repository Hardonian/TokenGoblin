# File-backed SQLite database. The directory is created automatically.
TG_DB_PATH=./data/tokengoblin.sqlite

# Set to 1 to force all non-env pricing to degrade as unknown pricing.
TG_DISABLE_DEFAULT_PRICING=0

# Optional JSON override or extension for the pricing registry.
# Keys use "provider:model" and prices are per 1M tokens in USD.
# TG_PRICING_TABLE_JSON={"openai:gpt-4o-mini":{"inputPerMillion":0.15,"outputPerMillion":0.6,"cachedInputPerMillion":0.075,"currency":"USD"}}

# Deterministic demo seed target.
TG_DEMO_TENANT_ID=demo-tenant
