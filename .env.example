# Copy this to .env and fill in your values

# Server
PORT=8080
DATABASE_URL="file:token_goblin.db"

# Stripe (required for billing)
# Use sk_test_... keys during development; switch to sk_live_... in production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Test price IDs below — replace with live price_... IDs for production
STRIPE_PRICE_PRO=price_1Thf1HC651G6xmqGtSCnlYIF
STRIPE_PRICE_ENTERPRISE=price_1Thf1IC651G6xmqGbiiVjlTy

# Internal webhook secret (generate: openssl rand -hex 32)
TG_INTERNAL_WEBHOOK_SECRET=change-me-in-production

# Frontend
NEXT_PUBLIC_TG_API_BASE=http://localhost:8080
# Must match server-side STRIPE_PRICE_* values (test IDs shown; swap for live)
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_1Thf1HC651G6xmqGtSCnlYIF
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_1Thf1IC651G6xmqGbiiVjlTy
