# File-backed SQLite database. The directory is created automatically.
TG_ADDR=:8080
TG_DB_PATH=./data/tokengoblin.sqlite

# Optional Postgres DSN. When set, Postgres migrations run from data/migrations.
# TG_DB_DSN=postgres://user:password@localhost:5432/tokengoblin?sslmode=disable

# Set to 1 to force all non-env pricing to degrade as unknown pricing.
TG_DISABLE_DEFAULT_PRICING=0

# Optional JSON override or extension for the pricing registry.
# Keys use "provider:model" and prices are per 1M tokens in USD.
# TG_PRICING_TABLE_JSON={"openai:gpt-4o-mini":{"inputPerMillion":0.15,"outputPerMillion":0.6,"cachedInputPerMillion":0.075,"currency":"USD"}}

# Deterministic demo seed target.
TG_DEMO_TENANT_ID=demo-tenant

# Optional Redis address for ingestion rate limiting and pricing cache diagnostics.
# TG_REDIS_ADDR=localhost:6379

# Frontend dashboard API base.
NEXT_PUBLIC_TG_API_BASE=http://localhost:8080

# Optional Stripe webhook signing secret for the Next.js Node runtime route
# at /api/stripe/webhook. The Go API intentionally does not process Stripe
# webhooks so raw-body signature verification is preserved in the correct runtime.
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
